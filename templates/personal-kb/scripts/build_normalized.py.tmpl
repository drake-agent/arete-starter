#!/usr/bin/env python3
"""Merge signal sources into a normalized event stream.

Combines chat, meeting, schedule, and voice inbox data into one JSONL file per day at
{{PERSONAL_KB_ROOT}}/data/normalized/YYYY-MM-DD.jsonl.
"""
from __future__ import annotations

import argparse
import json
from pathlib import Path
import re

ROOT = Path("{{PERSONAL_KB_ROOT}}")
TAG_RE = re.compile(r"#[\w-]+")


def load_json(path: Path):
    return json.loads(path.read_text(encoding="utf-8"))


def infer_tags(text: str):
    explicit = [t.lstrip("#").lower() for t in TAG_RE.findall(text or "")]
    words = [w.lower() for w in re.findall(r"[A-Za-z][A-Za-z0-9_-]{3,}", text or "")]
    return sorted(set(explicit + words[:3]))[:5]


def normalize_chat(doc: dict):
    for item in doc.get("signals", []):
        yield {
            "type": "chat",
            "timestamp": item.get("timestamp"),
            "content": item.get("content"),
            "source": doc.get("session_id"),
            "project_tags": infer_tags(item.get("content", "")),
        }


def normalize_schedule(doc: dict):
    for item in doc.get("events", []):
        content = f'{item.get("title", "Untitled")} participants={", ".join(item.get("participants", []))}'
        yield {
            "type": "schedule",
            "timestamp": item.get("time"),
            "content": content,
            "source": doc.get("source", "schedule"),
            "project_tags": infer_tags(content),
        }


def normalize_generic(doc: dict, key: str, event_type: str):
    for item in doc.get(key, []):
        content = item.get("content") or item.get("text") or item.get("title") or ""
        yield {
            "type": event_type,
            "timestamp": item.get("timestamp") or item.get("time"),
            "content": content,
            "source": doc.get("source", event_type),
            "project_tags": infer_tags(content),
        }


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--date", required=True)
    args = ap.parse_args()
    day = args.date
    events = []

    for path in sorted((ROOT / "data" / "chat-signals").glob(f"{day}_*.json")):
        events.extend(normalize_chat(load_json(path)))
    for path in sorted((ROOT / "data" / "schedule-signals").glob(f"{day}.json")):
        events.extend(normalize_schedule(load_json(path)))
    for folder, key, event_type in [
        ("meeting-signals", "meetings", "meeting"),
        ("voice-inbox", "items", "voice"),
    ]:
        for path in sorted((ROOT / "data" / folder).glob(f"{day}*.*json*")):
            events.extend(normalize_generic(load_json(path), key, event_type))

    out = ROOT / "data" / "normalized"
    out.mkdir(parents=True, exist_ok=True)
    lines = [json.dumps(event, ensure_ascii=False) for event in sorted(events, key=lambda x: str(x.get("timestamp", "")))]
    (out / f"{day}.jsonl").write_text("\n".join(lines) + ("\n" if lines else ""), encoding="utf-8")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
