#!/usr/bin/env python3
"""Cron preflight contract checker.
Usage: python runtime_contract.py --mode intel|wiki|prebrief|quality
Checks: required paths exist, signals fresh enough, delivery channel set.
Emits session fingerprint. Exit 0 = OK, exit 1 = blocked.
"""
import argparse, hashlib, json, os, socket, sys, time
from datetime import datetime, timedelta, timezone
from pathlib import Path

ROOT = Path("{{PERSONAL_KB_ROOT}}")
DATA = ROOT / "data"
WORKSPACE = Path("{{WORKSPACE}}")
KST = timezone(timedelta(hours=9))
NOW = datetime.now(KST)
TODAY = NOW.strftime("%Y-%m-%d")
STALE_HOURS = 26  # signals older than this are too stale

MODE_REQUIREMENTS: dict[str, dict] = {
    "intel": {
        "paths": [DATA / "normalized", ROOT / "wiki"],
        "signals": ["normalized"],
        "channel_env": "INTEL_DELIVERY_CHANNEL",
    },
    "wiki": {
        "paths": [ROOT / "wiki", DATA / "brain"],
        "signals": ["normalized"],
        "channel_env": None,
    },
    "prebrief": {
        "paths": [DATA / "schedule-signals", DATA / "normalized"],
        "signals": ["schedule-signals", "normalized"],
        "channel_env": "PREBRIEF_DELIVERY_CHANNEL",
    },
    "quality": {
        "paths": [DATA, ROOT / "wiki"],
        "signals": [],
        "channel_env": None,
    },
}


def check_path(p: Path) -> bool:
    return p.exists()


def check_signal_freshness(sig_type: str) -> bool:
    sig_dir = DATA / sig_type
    if not sig_dir.exists():
        return False
    files = sorted(sig_dir.iterdir(), key=lambda f: f.stat().st_mtime, reverse=True)
    if not files:
        return False
    age_h = (time.time() - files[0].stat().st_mtime) / 3600
    return age_h < STALE_HOURS


def fingerprint(mode: str) -> str:
    raw = f"{socket.gethostname()}:{TODAY}:{mode}"
    return hashlib.sha256(raw.encode()).hexdigest()[:16]


def main():
    parser = argparse.ArgumentParser(description="Runtime contract preflight")
    parser.add_argument("--mode", required=True, choices=MODE_REQUIREMENTS.keys())
    args = parser.parse_args()

    req = MODE_REQUIREMENTS[args.mode]
    errors: list[str] = []

    for p in req["paths"]:
        if not check_path(p):
            errors.append(f"missing path: {p}")

    for sig in req["signals"]:
        if not check_signal_freshness(sig):
            errors.append(f"stale or missing signal: {sig}")

    if req["channel_env"] and not os.environ.get(req["channel_env"]):
        errors.append(f"env not set: {req['channel_env']}")

    fp = fingerprint(args.mode)

    if errors:
        print(f"BLOCKED [{args.mode}] fingerprint={fp}")
        for e in errors:
            print(f"  ✗ {e}")
        sys.exit(1)
    else:
        print(f"OK [{args.mode}] fingerprint={fp}")
        sys.exit(0)


if __name__ == "__main__":
    main()
